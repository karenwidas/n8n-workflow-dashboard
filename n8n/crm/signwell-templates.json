{
  "name": "SignWell — Get Templates",
  "description": "Called by the Send for Signature modal on the dashboard. Fetches all active templates from SignWell and returns a simple id+name list to populate the template dropdown. Triggered every time the modal opens.",
  "nodes": [
    {
      "id": "sw-tpl-0001",
      "name": "Listen — Dashboard Requests Templates",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "parameters": {
        "httpMethod": "GET",
        "path": "signwell-templates",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "sw-tpl-0002",
      "name": "Get Templates from SignWell",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [450, 300],
      "parameters": {
        "method": "GET",
        "url": "https://www.signwell.com/api/v1/document_templates",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": { "id": "", "name": "SignWell API" }
      }
    },
    {
      "id": "sw-tpl-0003",
      "name": "Reshape to id+name Array",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300],
      "parameters": {
        "jsCode": "const templates = $input.all()[0].json.templates || [];\nreturn templates.map(t => ({ json: { id: t.id, name: t.name } }));"
      }
    },
    {
      "id": "sw-tpl-0004",
      "name": "Return Templates to Dashboard",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [850, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($input.all().map(i => i.json)) }}",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" }
            ]
          }
        }
      }
    }
  ],
  "connections": {
    "Listen — Dashboard Requests Templates": {
      "main": [[{ "node": "Get Templates from SignWell", "type": "main", "index": 0 }]]
    },
    "Get Templates from SignWell": {
      "main": [[{ "node": "Reshape to id+name Array", "type": "main", "index": 0 }]]
    },
    "Reshape to id+name Array": {
      "main": [[{ "node": "Return Templates to Dashboard", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "meta": { "instanceId": "" }
}
